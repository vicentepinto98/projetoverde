PORT=8080

# SMTP — any Gmail account with an App Password (not your account password)
# For local dev use your personal Gmail; production uses the school account.
# Generate an App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Where contact emails are delivered
# QA / local dev → your personal inbox
CONTACT_TO=vicenteppinto@gmail.com
# Production → school inbox
